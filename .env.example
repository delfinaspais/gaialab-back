# App
NODE_ENV=development
PORT=3000

# Orígenes CORS: sitio público (Next tienda) + panel admin (Next separado), opcional lista extra
PUBLIC_SITE_URL=http://localhost:3000
ADMIN_SITE_URL=http://localhost:3001
# Lista separada por comas si necesitás más orígenes:
# CORS_ORIGINS=https://stg.tienda.com

# Compat: si no definís PUBLIC_SITE_URL, se usa FRONTEND_URL
# FRONTEND_URL=http://localhost:3000

# URL pública del API (Mercado Pago webhook = /api/payments/webhook)
BACKEND_PUBLIC_URL=http://localhost:3000

# Segmento de URL del API de administración (sin slashes). Ej: "admin" o "panel-privado-xyz"
# Dashboard: GET /api/{ADMIN_API_SEGMENT}/dashboard
# Andreani: POST /api/{ADMIN_API_SEGMENT}/shipping/andreani/quote
ADMIN_API_SEGMENT=admin

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gaialab?schema=public"

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google Sign-In (backend verifica el ID token del cliente)
GOOGLE_CLIENT_ID=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=gaialab-products

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Andreani (ajustar URLs según documentación de tu contrato)
ANDREANI_BASE_URL=https://apis.andreani.com
ANDREANI_API_KEY=
ANDREANI_USERNAME=
ANDREANI_PASSWORD=
