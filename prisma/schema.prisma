generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InventoryLogType {
  IN
  OUT
  ADJUSTMENT
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  password      String?
  name          String?
  googleId      String?         @unique
  role          Role            @default(CUSTOMER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cart          Cart?
  orders        Order[]
  inventoryLogs InventoryLog[]
  productAuditActions ProductAuditLog[] @relation("AuditActor")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[] @relation("ProductCategories")
}

model Product {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  shortDescription    String?
  description         String    @db.Text
  sku                 String    @unique
  price               Decimal   @db.Decimal(12, 2)
  comparePrice        Decimal?  @db.Decimal(12, 2)
  costPrice           Decimal?  @db.Decimal(12, 2)
  trackQuantity       Boolean   @default(true)
  quantity            Int       @default(0) @map("stockQty")
  lowStockThreshold   Int?      @default(5)
  weightKg            Decimal?  @db.Decimal(10, 4)
  dimensions          Json?
  material            String?
  printTimeMinutes    Int?
  isActive            Boolean   @default(true)
  isDraft             Boolean   @default(false)
  isDeleted           Boolean   @default(false)
  deletedAt           DateTime?
  seoTitle            String?
  seoDescription      String?
  analyticsViewCount  Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  categories          Category[]       @relation("ProductCategories")
  tags                ProductTag[]     @relation("ProductToTag")
  images              ProductImage[]
  videos              ProductVideo[]
  cartItems           CartItem[]
  orderItems          OrderItem[]
  inventoryLogs       InventoryLog[]
  versions            ProductVersion[]
  auditLogs           ProductAuditLog[]

  @@index([isActive, isDraft, isDeleted])
  @@index([sku])
}

model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  publicId     String
  altText      String?
  thumbnailUrl String?
  position     Int     @default(0)
  isMain       Boolean @default(false)

  @@index([productId])
}

model ProductVideo {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?
  thumbnail String?
  position  Int     @default(0)

  @@index([productId])
}

model ProductTag {
  id       String    @id @default(cuid())
  name     String    @unique
  color    String?
  products Product[] @relation("ProductToTag")
}

model InventoryLog {
  id          String           @id @default(cuid())
  productId   String
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        InventoryLogType
  quantity    Int
  reason      String?
  reference   String?
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())

  @@index([productId])
  @@index([createdAt])
}

model ProductVersion {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  version   Int
  snapshot  Json
  createdAt DateTime @default(now())

  @@unique([productId, version])
  @@index([productId])
}

model ProductAuditLog {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model Cart {
  id             String     @id @default(cuid())
  userId         String?    @unique
  guestSessionId String?    @unique
  user           User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          CartItem[]
  updatedAt      DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int

  @@unique([cartId, productId])
  @@index([productId])
}

model Order {
  id                      String      @id @default(cuid())
  userId                  String?
  user                    User?       @relation(fields: [userId], references: [id])
  guestEmail              String?
  guestAccessToken        String?     @unique
  status                  OrderStatus @default(PENDING)
  subtotal                Decimal     @db.Decimal(12, 2)
  shippingCost            Decimal     @db.Decimal(12, 2) @default(0)
  total                   Decimal     @db.Decimal(12, 2)
  shippingName            String?
  shippingPhone           String?
  shippingStreet          String?
  shippingCity            String?
  shippingState           String?
  shippingZip             String?
  shippingCountry         String?     @default("AR")
  mercadopagoPreferenceId String?
  mercadopagoPaymentId    String?
  mercadopagoStatus       String?
  andreaniTrackingNumber  String?
  andreaniShipmentId      String?
  notes                   String?
  items                   OrderItem[]
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  quantity        Int
  priceAtPurchase Decimal @db.Decimal(12, 2)
  productName     String

  @@index([orderId])
  @@index([productId])
}
